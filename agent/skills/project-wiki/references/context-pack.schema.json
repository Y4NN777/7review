{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["project", "generated_at", "sections"],
  "properties": {
    "project": { "type": "string" },
    "generated_at": { "type": "string" },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "kind", "paths", "content", "review_triggers"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "kind": { "type": "string" },
          "paths": { "type": "array", "items": { "type": "string" } },
          "content": { "type": "string" },
          "review_triggers": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
