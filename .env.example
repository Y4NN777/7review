# ── GitLab ───────────────────────────────────────────────────────────────────
GITLAB_URL=https://gitlab.aiobi.tech
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_WEBHOOK_SECRET=your-webhook-secret

# ── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_API_URL=https://api.github.com
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# ── Agent paths ───────────────────────────────────────────────────────────────
SKILLS_DIR=./agent/skills
INPUT_PROFILE=./profiles/default.input-profile.json
CORPUS_ROOT=.
MEMORY_DIR=./.7review
INSTRUCTIONS_PATH=./agent/instructions.md
MAX_DIFF_TOKENS=6000
MAX_SUPPORTING_CORPUS_SECTIONS=3
HIL_CHANNEL=scm_comment          # scm_comment | slack | stdout
LISTEN_ADDR=:8080
HTTP_READ_HEADER_TIMEOUT_MS=5000
HTTP_READ_TIMEOUT_MS=30000
HTTP_WRITE_TIMEOUT_MS=120000
HTTP_IDLE_TIMEOUT_MS=120000
REVIEW_API_TOKEN=change-this-long-random-operator-token
WEBHOOK_WORKERS=4
WEBHOOK_QUEUE_SIZE=128
WEBHOOK_JOB_TIMEOUT_MS=900000
WEBHOOK_REVIEW_MODE=manual_first   # manual_first | auto | off
REVIEW_LABEL_INCLUDE=7review,ready-for-review
REVIEW_LABEL_EXCLUDE=no-review,wip,draft
REVIEW_ALLOWED_PROJECTS=
REVIEW_ALLOWED_REPOS=
REVIEW_BRANCH_INCLUDE=
REVIEW_BRANCH_EXCLUDE=

# ── Async approval channels ──────────────────────────────────────────────────
# Generic JSON bridge for local/internal tools:
# POST /channels/<channel>/inbound with X-7Review-Channel-Token.
CHANNEL_INBOUND_TOKEN=change-this-long-random-channel-token
CHANNEL_AUTHORIZED_SENDERS=operator@example.com

# Twilio WhatsApp provider:
# - outbound draft: Twilio Messages API
# - inbound reply: POST /channels/twilio/whatsapp
# - auth: X-Twilio-Signature, verified with TWILIO_AUTH_TOKEN
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=twilio-auth-token
# Approved WhatsApp template for business-initiated drafts outside the 24h window.
TWILIO_WHATSAPP_TEMPLATE_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SendGrid email provider:
# - outbound draft: SendGrid Mail Send API
# - inbound reply: POST /channels/sendgrid/inbound
# - auth: Authorization: Bearer ${SENDGRID_INBOUND_TOKEN}
#   or SendGrid signed webhook headers with SENDGRID_INBOUND_PUBLIC_KEY.
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_INBOUND_TOKEN=change-this-long-random-sendgrid-token
SENDGRID_INBOUND_PUBLIC_KEY=

# Mailgun email provider:
# - outbound draft: Mailgun Messages API
# - inbound reply: POST /channels/mailgun/inbound
# - auth: timestamp/token/signature fields verified with MAILGUN_SIGNING_KEY
MAILGUN_API_KEY=xxxxxxxxxxxxxxxxxxxx
MAILGUN_SIGNING_KEY=xxxxxxxxxxxxxxxxxxxx

# ── Required sidecars ─────────────────────────────────────────────────────────
HEADROOM_URL=http://localhost:8787
HEADROOM_TIMEOUT_MS=5000
MEMPALACE_URL=http://localhost:8788
MEMPALACE_TIMEOUT_MS=5000

# ── Multi-LLM Orchestration ───────────────────────────────────────────────────
# Option A: use orchestrator.yaml for full multi-provider role config.
# Explicit PROVIDER / REVIEW_MODEL / SMALL_MODEL env vars replace YAML role
# primaries and fallback chains while keeping max token caps and parallel settings.
ORCHESTRATOR_CONFIG=./orchestrator.yaml

# Option B: single-provider mode (used if ORCHESTRATOR_CONFIG is not set)
# PROVIDER=anthropic
# PROVIDER_API_KEY=sk-ant-...
# REVIEW_MODEL=claude-sonnet-4-6
# SMALL_MODEL=claude-haiku-4-5-20251001
#
# PROVIDER=openrouter
# PROVIDER_API_KEY=sk-or-...
# PROVIDER_BASE_URL=https://openrouter.ai/api
# REVIEW_MODEL=openai/gpt-4o
# SMALL_MODEL=openai/gpt-4o-mini
#
# PROVIDER=deepseek
# PROVIDER_API_KEY=sk-...
# PROVIDER_BASE_URL=https://api.deepseek.com
# REVIEW_MODEL=deepseek-chat
# SMALL_MODEL=deepseek-chat
#
# PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# REVIEW_MODEL=qwen2.5-coder-7b-16k:latest
# SMALL_MODEL=qwen2.5-coder:1.5b
# EMBEDDING_MODEL=nomic-embed-text:latest

# ── Per-provider API keys (used by orchestrator.yaml multi-provider config) ───
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxx

# Ollama: no key needed, just point at the local server.
# Use http://host.docker.internal:11434 from Docker Compose. Ollama must bind to
# a container-reachable address, for example OLLAMA_HOST=0.0.0.0:11434.
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text:latest

# openai_compat: for Together AI, Groq, vLLM, LM Studio, etc.
# PROVIDER=openai_compat
# PROVIDER_API_KEY=your-key
# PROVIDER_BASE_URL=https://api.together.xyz
